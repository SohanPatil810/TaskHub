# ============================================
# TaskHub Backend - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file with real credentials
# ============================================

# MySQL Database
DB_URL=jdbc:mysql://localhost:3306/taskhub?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=your_database_password_here

# JWT Configuration
JWT_SECRET=your_jwt_secret_here_must_be_at_least_64_characters_long_for_security

# Mail Configuration (Gmail SMTP)
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password_here
